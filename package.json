{
  "name": "adva-administracion",
  "version": "1.8.3",
  "type": "module",
  "description": "ADVA invoice and payment processing server with Gemini AI",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && node apps-script/build.js",
    "start": "node dist/server.js",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "upload:samples": "node --env-file=.env support/upload-samples.js"
  },
  "keywords": [
    "invoice",
    "automation",
    "gemini-ai",
    "google-sheets",
    "google-drive",
    "typescript",
    "fastify"
  ],
  "author": "Lucas Wall (ADVA)",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "node-cron": "^4.2.1",
    "p-queue": "^9.2.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/google-apps-script": "^2.0.8",
    "@types/node": "^24.12.2",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.5",
    "cli-progress": "^3.12.0",
    "esbuild": "^0.28.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
