{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "src/**",
      "apps-script/src/**",
      "apps-script/build.js",
      "apps-script/appsscript.json",
      "apps-script/tsconfig.json",
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      "nixpacks.toml",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
